# --- GitHub App authentication ---
GITHUB_APP_ID=0000000
# Private key must include the BEGIN/END markers. Either paste with real
# newlines (multi-line value) or use literal "\n" sequences.
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nREPLACE_ME\n-----END RSA PRIVATE KEY-----"
GITHUB_INSTALLATION_ID=00000000

# --- Default target owner ---
# Optional. Used as the fallback owner for org-scoped operations.
# Leave empty if you mainly create repos for the authenticated user.
GITHUB_ORGANIZATION=your-org

# --- (Optional) OAuth flow, only needed for user-level auth ---
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=

# --- FastAPI service ---
# API endpoints are protected with a static Bearer token:
#   Authorization: Bearer <API_AUTH_TOKEN>
API_AUTH_TOKEN=replace-with-a-long-random-secret
STATE_BACKEND=sql
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# --- Database ---
# Used only when STATE_BACKEND=sql.
# SQLite (default):
DATABASE_URL=sqlite:///./github_api.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/github_api
DB_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- GitHub client tuning ---
GITHUB_TIMEOUT_SECONDS=15
QUEUE_MAXSIZE=10000
QUEUE_WORKERS=64
